{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "pretty": true,
        "target": "ES6",
        "outDir": "./dist",
        "baseUrl": "./src",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"],
}
